    <string name="formula_desc_off_short">Brez avtomatskega izračuna</string>
    <string name="formula_desc_off_long">Ta metrika se ne izračuna samodejno. Vrednosti lahko vneseš ročno.</string>
    <string name="bf_deurenberg_1991_short">Klasična regresija za odrasle</string>
    <string name="bf_deurenberg_1991_long">Široko uporabljena formula za izračun telesne teže iz leta 1991. Primerna na splošno za odrasle osebe; lahko je manj natančna za zelo vitke ali zelo mišičaste posameznike.</string>
    <string name="bf_deurenberg_1992_short">Prilagojena za najstnike in odrasle</string>
    <string name="bf_deurenberg_1992_long">Varianta, prilagojena mlajšim uporabnikom. Splošna ocena; športniki ali ljudje z neobičajno telesno zgradbo lahko odstopajo od te ocene.</string>
    <string name="bf_eddy_1976_short">Zgodnji model, specifičen za spol</string>
    <string name="bf_eddy_1976_long">Starejša regresija z ločenimi koeficienti za moške in ženske. Preprosta in hitra, vendar ni prilagojena posebnim populacijam.</string>
    <string name="bf_gallagher_2000_non_asian_short">Gallagher (neazijski)</string>
    <string name="bf_gallagher_2000_non_asian_long">Referenčni model iz leta 2000 za neazijsko prebivalstvo. Koristna izhodiščna točka; natančnost se razlikuje glede na telesno konstitucijo.</string>
    <string name="bf_gallagher_2000_asian_short">Gallagher (azijsko)</string>
    <string name="bf_gallagher_2000_asian_long">Dodatni model, prilagojen azijskemu prebivalstvu. Uporabi ga, če bolje ustreza ozadju uporabnika.</string>
    <string name="bw_behnke_1963_short">Behnkejeva ocena skupne telesne vode</string>
    <string name="bw_behnke_1963_long">Klasična ocena celotne količine vode v telesu. Preprost pristop; ni prilagojen posameznim športnikom ali izjemnim primerom.</string>
    <string name="bw_delwaide_crenier_1973_short">Delwaide &amp; Crenier</string>
    <string name="bw_delwaide_crenier_1973_long">Formula za oceno skupne količine vode v telesu, ki poudarja telesno maso. Razumna splošna ocena; natančnost se razlikuje glede na telesno konstitucijo.</string>
    <string name="bw_hume_weyers_1971_short">Skupna količina vode Hume–Weyers</string>
    <string name="bw_hume_weyers_1971_long">Običajni model za oceno skupne količine vode v telesu na podlagi višine in teže, s koeficienti, specifičnimi po spolu.</string>
    <string name="bw_lee_song_kim_2001_short">Lee–Song–Kim</string>
    <string name="bw_lee_song_kim_2001_long">Najnovejša ocena skupne količine vode v telesu, kalibrirana na korejskih kohortah. Preveri, ali ta primerjava populacije ustreza.</string>
    <string name="lbm_boer_1984_short">Boer LBM (klinično)</string>
    <string name="lbm_boer_1984_long">Ocena mišične mase, ki je priljubljena v kliničnem okolju. Regresija glede na spol na podlagi višine in teže.</string>
    <string name="lbm_hume_1966_short">Hume LBM</string>
    <string name="lbm_hume_1966_long">Zgodnji model vitke telesne mase. Preprost in široko uporabljen; ni prilagojen zelo atletskim postavam.</string>
    <string name="lbm_weight_minus_bf_short">Teža − telesna maščoba</string>
    <string name="lbm_weight_minus_bf_long">Izračuna vitko telesno maso kot skupno težo minus maščobno maso, izračunano na podlagi izbrane formule za izračun telesne maščobe. Natančnost je odvisna od ocene telesne maščobe.</string>
